  "item": [
    {
      "name": "POST /api/orders",
      "item": [
        {
          "name": "Happy Path",
          "item": [
            {
              "name": "TC-01: Create standard order (6km, non-rush → $5)",
              "item": [
                {
                  "name": "Create order",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"cartSubtotal\": 30.00,\n  \"distanceInKm\": 6.0,\n  \"isRushHour\": false\n}"
                    },
                    "url": {
                      "raw": "{{baseUrl}}/api/orders",
                      "host": ["{{baseUrl}}"],
                      "path": ["api", "orders"]
                    }
                  },
                  "event": [
                    {
                      "listen": "test",
                      "script": {
                        "type": "text/javascript",
                        "exec": [
                          "pm.test('Status code is 201 Created', function () {",
                          "    pm.response.to.have.status(201);",
                          "});",
                          "",
                          "pm.test('Location header is present and valid', function () {",
                          "    pm.response.to.have.header('Location');",
                          "    var location = pm.response.headers.get('Location');",
                          "    pm.expect(location).to.match(/\\/api\\/orders\\/\\d+/);",
                          "});",
                          "",
                          "pm.test('Response body has correct schema', function () {",
                          "    var json = pm.response.json();",
                          "    pm.expect(json).to.have.property('id').that.is.a('number');",
                          "    pm.expect(json).to.have.property('cartSubtotal').that.is.a('number');",
                          "    pm.expect(json).to.have.property('distanceInKm').that.is.a('number');",
                          "    pm.expect(json).to.have.property('isRushHour').that.is.a('boolean');",
                          "    pm.expect(json).to.have.property('deliveryFee').that.is.a('number');",
                          "    pm.expect(json).to.have.property('createdAt').that.is.a('string');",
                          "});",
                          "",
                          "pm.test('Delivery fee is $5.00 (medium distance tier)', function () {",
                          "    pm.expect(pm.response.json().deliveryFee).to.eql(5);",
                          "});",
                          "",
                          "pm.test('Chain: save standardOrderId', function () {",
                          "    pm.environment.set('standardOrderId', pm.response.json().id);",
                          "});"
                        ]
                      }
                    }
                  ],
                  "response": []
                }
              ]
            },
