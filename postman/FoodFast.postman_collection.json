{
  "info": {
    "name": "FoodFast API Contract Tests",
    "description": "Integration tests for the FoodFast Delivery API.\n\nThis collection verifies the full API contract:\n- Status codes (201, 200, 204, 404)\n- Headers (Location, Content-Type)\n- Body schema and business logic\n- Data chaining between requests\n\nRun with Collection Runner for end-to-end verification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Order (POST)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cartSubtotal\": 30.00,\n  \"distanceInKm\": 6.0,\n  \"isRushHour\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// 1. Verify the HTTP Contract (Status Code)",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 2. Verify the Header Contract (Location)",
              "pm.test('Location header is present and valid', function () {",
              "    pm.response.to.have.header('Location');",
              "    var location = pm.response.headers.get('Location');",
              "    pm.expect(location).to.match(/\\/api\\/orders\\/\\d+/);",
              "});",
              "",
              "// 3. Verify the Body Contract (Schema)",
              "pm.test('Response body has correct schema', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id').that.is.a('number');",
              "    pm.expect(jsonData).to.have.property('cartSubtotal').that.is.a('number');",
              "    pm.expect(jsonData).to.have.property('distanceInKm').that.is.a('number');",
              "    pm.expect(jsonData).to.have.property('isRushHour').that.is.a('boolean');",
              "    pm.expect(jsonData).to.have.property('deliveryFee').that.is.a('number');",
              "    pm.expect(jsonData).to.have.property('createdAt').that.is.a('string');",
              "});",
              "",
              "// 4. Verify Business Logic (Fee is non-negative)",
              "pm.test('Delivery fee is non-negative', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.deliveryFee).to.be.at.least(0);",
              "});",
              "",
              "// 5. Chain data for subsequent requests",
              "pm.test('Extract orderId for subsequent requests', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('orderId', jsonData.id);",
              "    pm.expect(pm.environment.get('orderId')).to.not.be.undefined;",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "2. Get Order by ID (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders", "{{orderId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Returned order matches what was created', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(parseInt(pm.environment.get('orderId')));",
              "    pm.expect(jsonData.cartSubtotal).to.eql(30);",
              "    pm.expect(jsonData.distanceInKm).to.eql(6);",
              "    pm.expect(jsonData.isRushHour).to.eql(false);",
              "});",
              "",
              "pm.test('Delivery fee is calculated (not zero for non-free-delivery order)', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.deliveryFee).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "3. Calculate Fee (POST)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}/calculate-fee",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders", "{{orderId}}", "calculate-fee"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Fee breakdown has all required fields', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('orderId');",
              "    pm.expect(jsonData).to.have.property('cartSubtotal');",
              "    pm.expect(jsonData).to.have.property('distanceInKm');",
              "    pm.expect(jsonData).to.have.property('isRushHour');",
              "    pm.expect(jsonData).to.have.property('deliveryFee');",
              "    pm.expect(jsonData).to.have.property('total');",
              "});",
              "",
              "pm.test('Total equals cartSubtotal + deliveryFee', function () {",
              "    var jsonData = pm.response.json();",
              "    var expectedTotal = jsonData.cartSubtotal + jsonData.deliveryFee;",
              "    pm.expect(jsonData.total).to.eql(expectedTotal);",
              "});",
              "",
              "pm.test('Fee for 6km non-rush order is $5.00 (medium distance tier)', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.deliveryFee).to.eql(5);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "4. Get All Orders (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Array contains at least one order', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.length).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "5. Delete Order (DELETE)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders", "{{orderId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 204 No Content', function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "",
              "pm.test('Response body is empty', function () {",
              "    pm.expect(pm.response.text()).to.be.empty;",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "6. Get Deleted Order — 404 (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders", "{{orderId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('Error response has correct shape', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('error');",
              "    pm.expect(jsonData).to.have.property('orderId');",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}
